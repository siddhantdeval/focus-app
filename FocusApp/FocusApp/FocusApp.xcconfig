// FocusApp Configuration
// Architect-level configuration for Rust-Swift integration.

// 1. Framework & Library Search Paths
FRAMEWORK_SEARCH_PATHS = $(inherited) "$(PROJECT_DIR)/../"
LIBRARY_SEARCH_PATHS = $(inherited) "$(PROJECT_DIR)/../FocusCore.xcframework/macos-arm64_x86_64"

// 2. Search Paths for C-Headers (Crucial for Bridging Header)
HEADER_SEARCH_PATHS = $(inherited) "$(PROJECT_DIR)/../FocusCore.xcframework/macos-arm64_x86_64/Headers"
USER_HEADER_SEARCH_PATHS = $(inherited) "$(PROJECT_DIR)/../FocusCore.xcframework/macos-arm64_x86_64/Headers"

// 3. Bridging Header (Exposes Rust types directly to Swift)
SWIFT_OBJC_BRIDGING_HEADER = FocusApp/FocusApp-Bridging-Header.h

// 4. Linker Flags
OTHER_LDFLAGS = $(inherited) -lfocus_core

// 5. App Platform Settings
PRODUCT_NAME = FocusApp
GENERATE_INFOPLIST_FILE = YES
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon

// 6. Security & Build Settings
ENABLE_USER_SCRIPT_SANDBOXING = NO
SWIFT_VERSION = 5.0
