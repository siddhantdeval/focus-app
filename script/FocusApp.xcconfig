// FocusApp Configuration (Automated Pathing)
// This file ensures Rust C-types are visible to Swift.

// 1. Tell Xcode where the Headers are
HEADER_SEARCH_PATHS = $(inherited) "$(PROJECT_DIR)/../FocusCore.xcframework/macos-arm64_x86_64/Headers"

// 2. Point to the Bridging Header (Use PROJECT_DIR to be absolute)
SWIFT_OBJC_BRIDGING_HEADER = $(PROJECT_DIR)/FocusApp/FocusApp-Bridging-Header.h

// 3. Link the Rust Library
LIBRARY_SEARCH_PATHS = $(inherited) "$(PROJECT_DIR)/../FocusCore.xcframework/macos-arm64_x86_64"
OTHER_LDFLAGS = $(inherited) -lfocus_core

// 4. Build Settings
ENABLE_USER_SCRIPT_SANDBOXING = NO
SWIFT_VERSION = 5.0
